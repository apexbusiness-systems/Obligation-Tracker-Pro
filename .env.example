# ── Required (API server) ─────────────────────────────────────
PORT=3001
DATABASE_URL=postgresql://postgres:<password>@<host>:6543/postgres?sslmode=require
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ── Required (Frontend build) ─────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ── CORS (production) ─────────────────────────────────────────
# Comma-separated full origin URLs allowed by the API server
ALLOWED_ORIGINS=https://dueradar.icu,https://www.dueradar.icu

# ── FlowC integration ─────────────────────────────────────────
FLOWC_WEBHOOK_SECRET=whsec_xxx
# Workspace that FlowC signals are assigned to (slug or UUID fallback)
FLOWC_WORKSPACE_ID=
# Optional: outbound callback after each signal is processed
FLOWC_CALLBACK_URL=
FLOWC_CALLBACK_SECRET=

# ── Email reminders (optional) ────────────────────────────────
ENABLE_REMINDER_SCHEDULER=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=noreply@dueradar.icu

# ── Observability (optional) ──────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ── Groq AI enrichment (optional, disabled by default) ────────
ENABLE_GROQ_AI=false
GROQ_API_KEY=gsk_xxx
